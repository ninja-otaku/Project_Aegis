# ── Project Aegis — environment configuration ──────────────────────────────
#
# Copy this file to .env and edit as needed.
# All values can also be passed as real environment variables (they take
# precedence over .env).

# ── Intake ──────────────────────────────────────────────────────────────────

# Intake source.  One of: phone | capture
INTAKE_MODE=phone

# Zero-based index of the capture card / webcam device (capture mode only).
CAPTURE_DEVICE_INDEX=0

# Port that uvicorn listens on.
PHONE_WS_PORT=8765

# ── Frame Compression (Phone Intake) ────────────────────────────────────────
# Lower = faster pipeline. Tune to your network and machine.
PHONE_FRAME_WIDTH=640
PHONE_COMPRESS_QUALITY=70

# ── AI Provider ─────────────────────────────────────────────────────────────
# Options: claude | gemini | openai | ollama
# Only set the API key for the provider you are using.
AI_PROVIDER=claude

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama requires no API key. Run locally: ollama pull llava
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava

# How often to run AI analysis on the latest frame (milliseconds).
ANALYSIS_INTERVAL_MS=2000

# System prompt. Override to customise for a specific game or analysis style.
ANALYSIS_SYSTEM_PROMPT=You are an expert AI gaming companion. Analyse the game screenshot and return a JSON object with: game_state (brief current situation), threats (list of immediate threats or opportunities), recommendation (the single most important action to take right now), and confidence (low/medium/high). Be direct, tactical, and concise.

# ── Frame Diff (API cost optimization) ──────────────────────────────────────
# Skip AI call if frame hasn't changed enough. 0.02 = ~2% pixel change.
# Tune up for fast-paced games (more motion), down for slow/turn-based games.
FRAME_DIFF_ENABLED=true
FRAME_DIFF_THRESHOLD=0.02

# ── TLS (required for phone camera access on most browsers) ─────────────────
# Run: python scripts/generate_cert.py  then set TLS_ENABLED=true
TLS_ENABLED=false
TLS_CERT_PATH=certs/cert.pem
TLS_KEY_PATH=certs/key.pem

# ── TTS ─────────────────────────────────────────────────────────────────────
# Speak the recommendation aloud via system TTS (requires: pip install pyttsx3)
TTS_ENABLED=false

# ── History ──────────────────────────────────────────────────────────────────
HISTORY_MAX_ENTRIES=50
