# ── Project Aegis — environment configuration ──────────────────────────────
#
# Copy this file to .env and edit as needed.
# All values can also be passed as real environment variables (they take
# precedence over .env).

# Intake source.  One of: phone | capture
INTAKE_MODE=phone

# Zero-based index of the capture card / webcam device (capture mode only).
# On Linux this maps to /dev/videoN; on Windows to DirectShow device N.
CAPTURE_DEVICE_INDEX=0

# Port that uvicorn listens on.
# The phone browser frontend connects to ws://<server-ip>:<port>/ws/intake
PHONE_WS_PORT=8765

# ── AI provider ────────────────────────────────────────────────────────────

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for vision analysis.
CLAUDE_MODEL=claude-opus-4-6

# How often to run AI analysis on the latest frame (milliseconds).
# Lower = more responsive but more expensive.  Default: 2000 (2 s).
ANALYSIS_INTERVAL_MS=2000

# System prompt sent with every vision request.  Override to customise
# for a specific game or analysis style.
ANALYSIS_SYSTEM_PROMPT=You are an expert AI gaming companion. Analyse the game screenshot and return a JSON object with: game_state (brief current situation), threats (list of immediate threats or opportunities), recommendation (the single most important action to take right now), and confidence (low/medium/high). Be direct, tactical, and concise.

# ── TTS ─────────────────────────────────────────────────────────────────────

# Speak the recommendation aloud via system TTS (requires: pip install pyttsx3).
TTS_ENABLED=false

# ── History ──────────────────────────────────────────────────────────────────

# Number of past analyses to retain (accessible via GET /history).
HISTORY_MAX_ENTRIES=50
